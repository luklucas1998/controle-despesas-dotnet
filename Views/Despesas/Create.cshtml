@model ControleDespesas.Models.Despesa

@{
    ViewData["Title"] = "Nova Despesa";
}

<h2 class="mb-4 fw-bold">➕ Nova Despesa</h2>

<div class="row justify-content-center">
    <div class="col-md-6">

        <div class="card p-4 shadow">

            <form asp-action="Create">

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label class="form-label">Nome</label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Mercado" />
                    <span asp-validation-for="Nome" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Valor</label>
                    <input asp-for="Valor" class="form-control" placeholder="Ex: 150.00" />
                    <span asp-validation-for="Valor" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Data</label>
                    <input asp-for="Data" type="date" class="form-control" />
                    <span asp-validation-for="Data" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Categoria</label>
                    <input asp-for="Categoria" class="form-control" placeholder="Ex: Alimentação" />
                    <span asp-validation-for="Categoria" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-secondary">Voltar</a>

                    <button type="submit" class="btn btn-success">
                        💾 Salvar
                    </button>
                </div>

            </form>

        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}